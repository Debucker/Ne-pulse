# NE-PULSE server — production configuration blueprint.
#
# IMPORTANT: cmd/server currently reads its configuration from command-line
# flags (see `go run ./cmd/server -h` for the full list), not directly from
# environment variables. deploy/ne-pulse-backend.service reads this file via
# EnvironmentFile= and substitutes these variables straight into the
# server's ExecStart flags, so the KEY names below must match exactly.
#
# deploy/deploy.sh copies this file to /etc/ne-pulse/ne-pulse.env on the
# server. Copy it there yourself first (`cp .env.production.example
# /etc/ne-pulse/ne-pulse.env` after `mkdir -p /etc/ne-pulse`) and fill in
# your actual values — it's gitignored and deploy.sh will refuse to
# overwrite an existing one. Never commit real values, especially
# REDIS_PASSWORD and NOTIFY_WEBHOOK_URL.

# --- Networking ---
# Bound to 127.0.0.1 only by the systemd unit (never exposed directly to
# the internet) — Caddy is the only public-facing listener; see
# deploy/Caddyfile.
HTTP_PORT=8080
GRPC_PORT=50051
WORKERS=8
QUEUE_DEPTH=8192

# --- Public domain (used by deploy.sh to render deploy/Caddyfile) ---
DOMAIN=ne-pulse.com

# --- Storage backend ---
# "redis" (recommended for production — real time-series persistence,
# with automatic in-memory fallback if RedisTimeSeries isn't loaded) or
# "memory" (no persistence; fine for a demo/staging environment only).
SIM_MODE=redis
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# --- CORS / WebSocket origin allowlist ---
# Comma-separated, no wildcards. Must exactly match the scheme + host your
# production frontend is served from — keep this restricted to the real
# domain in production; do not add http://localhost:* entries here (those
# are only meaningful for local development, handled by cmd/server's own
# built-in default when this flag is omitted entirely).
CORS_ALLOWED_ORIGINS=https://ne-pulse.com,https://www.ne-pulse.com

# --- Per-IP rate limiting (internal/ratelimit) ---
# Protects the dashboard/control/ingress HTTP API from a single flooding or
# misbehaving client. 5 req/s comfortably covers one real device's own
# telemetry cadence (~4Hz) while still capping any single IP.
RATE_LIMIT_PER_SECOND=5
RATE_LIMIT_BURST=5

# --- Third-party hardware ingress auth (internal/ingress.TokenAuthenticator) ---
# Comma-separated list of valid X-API-Token values for POST
# /api/ingress/hardware — this is the "Phase 2" open door for third-party
# ESP32/MPU6050 rigs and other external hardware. Generate one token per
# integration partner/device batch (e.g. `openssl rand -hex 32`), not one
# shared secret for everyone, so a single compromised token can be revoked
# without rotating every other integration.
#
# LEAVING THIS BLANK MEANS THE ENDPOINT IS FULLY OPEN — no authentication
# at all, matching this project's behavior before Phase 2. Do not deploy
# publicly with this blank once you're actually onboarding third parties.
API_TOKENS=

# --- Radar detection tuning (production defaults — see internal/detector) ---
RADAR_THRESHOLD=50
RADAR_COINCIDENCE_WINDOW=50ms
RADAR_COOLDOWN=10s

# --- Emergency notification egress (optional) ---
# External gateway (Telegram Bot relay, Twilio webhook, etc.) to POST
# emergency alerts to. Leave blank to disable notification egress entirely.
NOTIFY_WEBHOOK_URL=
NOTIFY_SAFETY_MARGIN=10
