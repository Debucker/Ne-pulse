# NE-PULSE server — production configuration blueprint.
#
# IMPORTANT: cmd/server currently reads its configuration from command-line
# flags (see `go run ./cmd/server -h` for the full list), not directly from
# environment variables. This file documents the recommended PRODUCTION
# VALUE for each flag as KEY=VALUE — export these in your process
# manager/systemd unit/Dockerfile and translate them into the equivalent
# `-flag=value` arguments on the server's start command, for example:
#
#   ./server \
#     -http-addr=":${HTTP_PORT}" \
#     -addr=":${GRPC_PORT}" \
#     -sim-mode="${SIM_MODE}" \
#     -redis-addr="${REDIS_ADDR}" \
#     -redis-password="${REDIS_PASSWORD}" \
#     -cors-allowed-origins="${CORS_ALLOWED_ORIGINS}" \
#     -notify-webhook-url="${NOTIFY_WEBHOOK_URL}"
#
# Copy this file to `.env.production` (gitignored — never commit real
# values, especially REDIS_PASSWORD and NOTIFY_WEBHOOK_URL) and fill in
# your actual deployment's values.

# --- Networking ---
HTTP_PORT=8080
GRPC_PORT=50051

# --- Storage backend ---
# "redis" (recommended for production — real time-series persistence,
# with automatic in-memory fallback if RedisTimeSeries isn't loaded) or
# "memory" (no persistence; fine for a demo/staging environment only).
SIM_MODE=redis
REDIS_ADDR=your-redis-host:6379
REDIS_PASSWORD=
REDIS_DB=0

# --- CORS / WebSocket origin allowlist ---
# Comma-separated. Must exactly match the scheme + host your production
# frontend is served from.
CORS_ALLOWED_ORIGINS=https://ne-pulse.com,https://www.ne-pulse.com

# --- Radar detection tuning (production defaults — see internal/detector) ---
RADAR_THRESHOLD=50
RADAR_COINCIDENCE_WINDOW=50ms
RADAR_COOLDOWN=10s

# --- Emergency notification egress (optional) ---
# External gateway (Telegram Bot relay, Twilio webhook, etc.) to POST
# emergency alerts to. Leave blank to disable notification egress entirely.
NOTIFY_WEBHOOK_URL=
NOTIFY_SAFETY_MARGIN=10
