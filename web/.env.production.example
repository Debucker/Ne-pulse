# NE-PULSE web — production environment blueprint.
#
# Copy this file to `.env.production` (gitignored — never commit real
# values) and fill in your actual deployed API/WebSocket origin below.
# NEXT_PUBLIC_* variables are inlined into the client bundle at build
# time, so they are visible to anyone who loads the site — never put a
# secret in a NEXT_PUBLIC_ variable.

# Base URL of the deployed Go server's HTTP sidecar (gRPC listens on a
# separate port and is never reached directly from the browser).
NEXT_PUBLIC_API_URL=https://api.ne-pulse.com

# WebSocket origin for the live telemetry feed. Must use wss:// in
# production (plain ws:// will be blocked as mixed content by browsers
# once the site itself is served over https://).
NEXT_PUBLIC_WS_URL=wss://api.ne-pulse.com

# Optional X-API-Token sent by the Lite dashboard's crowdsourced mesh
# telemetry (POST /api/ingress/hardware). Since this is a NEXT_PUBLIC_
# variable it is fully public the moment the site ships -- it cannot gate
# access the way a token issued to a real hardware partner can. Provision
# one low-stakes token here (distinct from real hardware-partner tokens in
# the backend's API_TOKENS) if the backend has -api-tokens configured and
# you still want ordinary browsers to reach the endpoint; leave blank to
# send no auth header, matching the endpoint's open-by-default behavior.
NEXT_PUBLIC_HARDWARE_API_TOKEN=
